{
  "name": "@lendasat/lendaswap-sdk-pure",
  "version": "0.2.11",
  "description": "Lendaswap Client SDK - Pure TypeScript, React Native compatible",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./delegate": {
      "types": "./dist/delegate.d.ts",
      "import": "./dist/delegate.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate:api": "openapi-typescript openapi.json -o src/generated/api.ts",
    "prepare": "tsc -p tsconfig.build.json",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@arkade-os/sdk": "^0.4.6",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^1.7.1",
    "@scure/bip32": "^1.6.2",
    "@scure/bip39": "^1.5.4",
    "@scure/btc-signer": "^2.0.1",
    "dexie": "^4.2.1",
    "openapi-fetch": "^0.15.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.6.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "openapi-typescript": "^7.10.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "lendaswap",
    "bitcoin",
    "swap",
    "ark",
    "arkade",
    "react-native"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lendasat/lendaswap-sdk.git",
    "directory": "client-sdk/ts-pure-sdk"
  },
  "publishConfig": {
    "access": "public"
  }
}
