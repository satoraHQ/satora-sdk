{
  "name": "@lendasat/lendaswap-sdk-pure",
  "version": "0.2.44",
  "description": "Lendaswap Client SDK - Pure TypeScript, React Native compatible",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    },
    "./delegate": {
      "types": "./dist/delegate.d.ts",
      "import": "./dist/delegate.js",
      "require": "./dist/delegate.cjs"
    },
    "./cctp-bridge": {
      "types": "./dist/cctp-bridge/index.d.ts",
      "import": "./dist/cctp-bridge/index.js",
      "require": "./dist/cctp-bridge/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate:api": "openapi-typescript openapi.json -o src/generated/api.ts",
    "sync-version": "node scripts/sync-version.mjs",
    "prebuild": "node scripts/sync-version.mjs",
    "version": "node scripts/sync-version.mjs && git add src/version.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version && node scripts/sync-version.mjs",
    "changeset:release": "pnpm build && changeset publish",
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@arkade-os/sdk": "^0.4.37",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.0.0",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "@scure/btc-signer": "^2.0.1",
    "@zerodev/sdk": "^5.5.0",
    "dexie": "^4.4.2",
    "openapi-fetch": "^0.17.0",
    "viem": "^2.52.2"
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.6.2"
  },
  "peerDependencies": {
    "@circle-fin/adapter-viem-v2": "^1.8.0",
    "@circle-fin/bridge-kit": "^1.8.0"
  },
  "peerDependenciesMeta": {
    "@circle-fin/adapter-viem-v2": {
      "optional": true
    },
    "@circle-fin/bridge-kit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@changesets/cli": "^2.31.0",
    "@circle-fin/adapter-viem-v2": "^1.8.2",
    "@circle-fin/bridge-kit": "^1.8.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@zerodev/sdk": "^5.5.10",
    "openapi-typescript": "^7.10.1",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "viem": "^2.52.2",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "lendaswap",
    "bitcoin",
    "swap",
    "ark",
    "arkade",
    "react-native"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/satoraHQ/lendaswap-sdk.git",
    "directory": "client-sdk/ts-pure-sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "bufferutil",
      "esbuild",
      "utf-8-validate"
    ]
  }
}
