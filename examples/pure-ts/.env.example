# Lendaswap CLI Configuration
# Copy this file to .env and customize as needed

# API base URL (default: https://api.satora.io/)
# LENDASWAP_API_URL=https://api.satora.io/

# BIP39 mnemonic for BTC wallet (Lightning/Arkade/On-chain)
# If not set, a new mnemonic will be generated and stored
# MNEMONIC="abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about"

# BIP39 mnemonic for EVM wallet (Polygon/Arbitrum/Ethereum)
# Required for: fund, evm-refund, evm-claim, evm-balances commands
# Can be the same as MNEMONIC or a separate wallet
# EVM_MNEMONIC="abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about"

# Org code for swap tracking (optional)
# LENDASWAP_ORG_CODE=your-org-code-here

# SQLite database path (default: ~/.lendaswap/data.db)
# LENDASWAP_DB_PATH=./data.db

# Esplora API URL for Bitcoin transaction broadcasting (optional)
# Default: mempool.space for mainnet
# ESPLORA_URL=https://mempool.space/api
