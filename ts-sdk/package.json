{
  "name": "@satora/sdks",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": "^22"
  },
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "build": "pnpm --filter @lendasat/lendaswap-sdk-pure --filter './packages/**...' run build",
    "test": "pnpm --filter './packages/**' run test",
    "test:run": "pnpm build && pnpm --filter './packages/**' run test:run",
    "lint": "pnpm --filter './packages/**' run lint",
    "lint:fix": "pnpm --filter './packages/**' run lint:fix",
    "check-types": "pnpm build && pnpm --filter './packages/**' run check-types",
    "clean": "pnpm --filter @lendasat/lendaswap-sdk-pure --filter './packages/**' run clean && rm -rf node_modules",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@changesets/cli": "^2.31.0",
    "typescript": "^5.7.0"
  }
}
